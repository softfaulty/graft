#!/bin/sh

set -eu

project_root=$(CDPATH= cd "$(dirname "$0")" && pwd)
cd "$project_root"

select_android_ndk() {
    ndk_candidate=$1

    if [ ! -f "$ndk_candidate/source.properties" ]; then
        return 1
    fi

    ndk_revision=$(awk -F '=' '
        /^Pkg.Revision/ {
            revision = $2
            sub(/^[[:space:]]*/, "", revision)
            print revision
            exit
        }
    ' "$ndk_candidate/source.properties")

    if [ -z "$ndk_revision" ]; then
        return 1
    fi

    for ndk_prebuilt in "$ndk_candidate"/toolchains/llvm/prebuilt/*; do
        ndk_clang="$ndk_prebuilt/bin/aarch64-linux-android29-clang"

        if [ -x "$ndk_clang" ]; then
            android_ndk_path=$ndk_candidate
            android_ndk_revision=$ndk_revision
            android_clang_path=$ndk_clang
            return 0
        fi
    done

    return 1
}

find_android_ndk() {
    android_ndk_path=
    android_ndk_revision=
    android_clang_path=

    if [ -n "${ANDROID_NDK_HOME:-}" ]; then
        if select_android_ndk "$ANDROID_NDK_HOME"; then
            return 0
        fi

        echo "dev: ANDROID_NDK_HOME is not a valid ARM64 android NDK: $ANDROID_NDK_HOME" >&2
        return 1
    fi

    if [ -n "${ANDROID_NDK_ROOT:-}" ]; then
        if select_android_ndk "$ANDROID_NDK_ROOT"; then
            return 0
        fi

        echo "dev: ANDROID_NDK_ROOT is not a valid ARM64 Android NDK: $ANDROID_NDK_ROOT" >&2
        return 1
    fi

    for ndk_candidate in \
        /opt/homebrew/share/android-ndk \
        /usr/local/share/android-ndk; do
        if select_android_ndk "$ndk_candidate"; then
            return 0
        fi
    done

    user_home=${HOME:-}

    for sdk_root in \
        "${ANDROID_SDK_ROOT:-}" \
        "${ANDROID_HOME:-}" \
        "$user_home/Library/Android/sdk" \
        "$user_home/Android/Sdk"; do
        if [ -z "$sdk_root" ] || [ ! -d "$sdk_root" ]; then
            continue
        fi

        for ndk_candidate in "$sdk_root"/ndk/*; do
            select_android_ndk "$ndk_candidate" || true
        done

        if [ -z "$android_ndk_path" ]; then
            select_android_ndk "$sdk_root/ndk-bundle" || true
        fi

        if [ -n "$android_ndk_path" ]; then
            return 0
        fi
    done

    echo "dev: Android NDK not found" >&2
    echo "set ANDROID_NDK_HOME to an NDK directory or install a side-by-side NDK in the Android SDK" >&2
    return 1
}

find_host_tool() {
    host_tool_name=$1
    host_tool_formula=$2
    host_tool_path=$(command -v "$host_tool_name" 2>/dev/null || true)

    if [ -n "$host_tool_path" ]; then
        return 0
    fi

    if [ -n "$host_tool_formula" ] && command -v brew >/dev/null 2>&1; then
        homebrew_prefix=$(brew --prefix 2>/dev/null || true)

        for host_tool_candidate in \
            "$homebrew_prefix/opt/$host_tool_formula/bin/$host_tool_name" \
            "$homebrew_prefix/opt/$host_tool_formula/sbin/$host_tool_name"; do
            if [ -x "$host_tool_candidate" ]; then
                host_tool_path=$host_tool_candidate
                return 0
            fi
        done
    fi

    return 1
}

check_host_tool() {
    host_tool_name=$1
    host_tool_formula=$2
    host_tool_fix=$3

    if find_host_tool "$host_tool_name" "$host_tool_formula"; then
        printf 'ok:      %-12s %s\n' "$host_tool_name" "$host_tool_path"
        return
    fi

    printf 'missing: %-12s fix: %s\n' "$host_tool_name" "$host_tool_fix" >&2
    doctor_errors=$((doctor_errors + 1))
}

doctor() {
    doctor_errors=0

    case $(uname -s) in
        Darwin)
            platform_tools_fix='brew install --cask android-platform-tools'
            ext4_tools_fix='brew install e2fsprogs'
            python_fix='brew install python'
            java_fix='brew install openjdk'
            zip_tools_fix='brew install zip unzip'
            tar_fix='xcode-select --install'
            xz_fix='brew install xz'
            lz4_fix='brew install lz4'
            ndk_fix='brew install --cask android-ndk'
            ;;
        Linux)
            platform_tools_fix='sudo apt-get install adb fastboot'
            ext4_tools_fix='sudo apt-get install e2fsprogs'
            python_fix='sudo apt-get install python3'
            java_fix='sudo apt-get install default-jdk'
            zip_tools_fix='sudo apt-get install zip unzip'
            tar_fix='sudo apt-get install tar'
            xz_fix='sudo apt-get install xz-utils'
            lz4_fix='sudo apt-get install lz4'
            ndk_fix='install the NDK with the Android SDK Manager and set ANDROID_NDK_HOME'
            ;;
        *)
            platform_tools_fix='install Android SDK Platform-Tools and add them to PATH'
            ext4_tools_fix='install e2fsprogs and add its bin and sbin directories to PATH'
            python_fix='install Python 3 and add python3 to PATH'
            java_fix='install a JDK and add java and javac to PATH'
            zip_tools_fix='install zip and unzip and add them to PATH'
            tar_fix='install tar and add it to PATH'
            xz_fix='install xz and add it to PATH'
            lz4_fix='install lz4 and add it to PATH'
            ndk_fix='install the Android NDK and set ANDROID_NDK_HOME'
            ;;
    esac

    check_host_tool adb '' "$platform_tools_fix"
    check_host_tool fastboot '' "$platform_tools_fix"
    check_host_tool python3 python "$python_fix"
    check_host_tool java openjdk "$java_fix"
    check_host_tool javac openjdk "$java_fix"

    check_host_tool e2fsck e2fsprogs "$ext4_tools_fix"
    check_host_tool resize2fs e2fsprogs "$ext4_tools_fix"
    check_host_tool debugfs e2fsprogs "$ext4_tools_fix"
    check_host_tool mke2fs e2fsprogs "$ext4_tools_fix"

    check_host_tool zip zip "$zip_tools_fix"
    check_host_tool unzip unzip "$zip_tools_fix"
    check_host_tool tar '' "$tar_fix"
    check_host_tool xz xz "$xz_fix"
    check_host_tool lz4 lz4 "$lz4_fix"

    if find_android_ndk; then
        printf 'ok:      %-12s %s (%s)\n' "android-ndk" "$android_ndk_path" "$android_ndk_revision"
        printf 'ok:      %-12s %s\n' "arm64-clang" "$android_clang_path"
    else
        printf 'missing: %-12s fix: %s\n' "android-ndk" "$ndk_fix" >&2
        doctor_errors=$((doctor_errors + 1))
    fi

    if [ "$doctor_errors" -gt 0 ]; then
        printf 'doctor: %s required dependencies missing\n' "$doctor_errors" >&2
        return 1
    fi

    echo "doctor: all required dependencies found"
}

show_help() {
    cat <<'EOF'
usage: ./dev <command>

available now:
    help             show this help
    fmt              format the Rust workspace
    fmt-check        check Rust formatting without changing files
    test [args...]   test the Rust workspace
    build [args...]  build the Rust workspace
    build-runtime    build graftd, graftctl, su and graft-sshd
    doctor           check host and Android build dependencies
reserved:
    build-recovery   build the recovery patcher
    package          package release artifacts
    deploy           deploy runtime artifacts through adb
    probe            inspect a connected device
    patch            stage patched artifacts
    verify           verify staged artifacts
    install          install verified artifacts
    logs             stream graft logs from a connected device
EOF
}

unimplemented() {
    echo "dev: $1 is unimplemented" >&2
    exit 2
}

command=${1:-help}

if [ "$#" -gt 0 ]; then
    shift
fi

case "$command" in
    help|-h|--help)
        show_help
        ;;
    fmt)
        cargo fmt --all
        ;;
    fmt-check)
        cargo fmt --all -- --check
        ;;
    test)
        cargo test --workspace "$@"
        ;;
    build)
        cargo build --workspace "$@"
        ;;
    build-runtime)
        cargo build \
            --package graftd \
            --package graftctl \
            --package su \
            --package graft-sshd \
            "$@"
        ;;
    doctor)
        doctor
        ;;
    build-recovery|package|deploy|probe|patch|verify|install|logs)
        unimplemented "$command"
        ;;
    *)
        echo "dev: unknown command: $command" >&2
        echo "run './dev help' for available commands" >&2
        exit 2
        ;;
esac
